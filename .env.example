# ---------------------------------------------------------------
# DEPLOYMENT CONFIGURATION
# Set these as GitHub Actions repository variables:
# Settings → Secrets and variables → Actions → Variables
# ---------------------------------------------------------------

# Sub-path for GitHub Pages project deployments.
# If deploying to https://yourname.github.io/homelab-hero, set to:
#   VITE_BASE_PATH=/homelab-hero
# If deploying to a custom domain root, leave as:
#   VITE_BASE_PATH=/
VITE_BASE_PATH=/homelab-hero

# Full base URL used for generating share links.
# e.g. https://yourname.github.io/homelab-hero
# or   https://yourdomain.com
VITE_BASE_URL=https://yourname.github.io/homelab-hero

# CORS proxy for fetching remote markdown files on the share page.
# The target URL is percent-encoded and appended directly to this value.
# Defaults to https://corsproxy.io/?url= if not set.
VITE_CORS_PROXY_URL=https://corsproxy.io/?url=
